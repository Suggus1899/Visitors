{
  "name": "@logmaster/server",
  "version": "1.0.0",
  "description": "LogMaster - Backend de Control de Acceso",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "ts-node src/server.ts",
    "dev": "nodemon",
    "seed": "ts-node src/scripts/seed-comprehensive.ts",
    "seed:clean": "ts-node src/scripts/seed-comprehensive.ts --clean",
    "db:reset": "ts-node src/scripts/reset-db.ts",
    "migrate": "ts-node src/scripts/apply-migrations.ts",
    "migrate:photos": "ts-node src/scripts/migrate-photos-to-blob.ts",
    "audit": "pnpm audit --audit-level=high",
    "backup:full": "powershell -NoProfile -Command \"$d=(Get-Date).ToString('yyyyMMdd_HHmmss'); pg_dump -Fc -U postgres -h localhost visitors > ('../backups/backup_' + $d + '.dump')\"",
    "backup:schema": "powershell -NoProfile -Command \"$d=(Get-Date).ToString('yyyyMMdd'); pg_dump -s -U postgres -h localhost visitors > ('../backups/schema_' + $d + '.sql')\"",
    "backup:monitor": "psql -U postgres -h localhost -c \"SELECT pg_size_pretty(pg_total_relation_size('\\\"Visitors\\\"'));\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.1",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.4",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.18",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "author": "",
  "license": "ISC"
}
