# Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ==========================================
# Server Configuration
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# Database Configuration
# ==========================================
# Path to store database file (optional, defaults to /data)
DB_PATH=./data

# SQLCipher encryption key
# IMPORTANT: In production with Electron, this will be managed by KeyManager (stored in OS keychain)
# For development only, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DB_ENCRYPTION_KEY=your_64_character_hex_key_here

# ==========================================
# JWT Authentication
# ==========================================
# IMPORTANT: In production with Electron, JWT_SECRET will be managed by KeyManager (stored in OS keychain)
# For development only, generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=your_secret_key_minimum_32_characters_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ==========================================
# Data Encryption (for sensitive fields)
# ==========================================
# IMPORTANT: In production with Electron, this will be managed by KeyManager (stored in OS keychain)
# For development only, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=your_encryption_key_32_bytes_hex_here

# ==========================================
# Backup Configuration
# ==========================================
BACKUP_PATH=./Backups
# IMPORTANT: In production with Electron, this will be managed by KeyManager (stored in OS keychain)
# BACKUP_PASSWORD=your_backup_password_here

# ==========================================
# GDPR Compliance
# ==========================================
# Number of days to retain visitor data after checkout
DATA_RETENTION_DAYS=60

# ==========================================
# Security
# ==========================================
# Bcrypt rounds for password hashing (higher = more secure but slower)
# Recommended: 12 for production
BCRYPT_ROUNDS=12

# Maximum login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Rate limiting (requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Email Configuration (for password reset)
# ==========================================
# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email sender address
EMAIL_FROM=noreply@afvisitorsystem.com

# Application URL (for password reset links)
APP_URL=http://localhost:5173
