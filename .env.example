# ============================================================
# LogMaster — Única Fuente de Verdad para Variables de Entorno
# ============================================================
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env al control de versiones.

# ==========================================
# Server Configuration
# ==========================================
PORT=3001
NODE_ENV=development

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# Path for local files (photos backup, logs)
DB_PATH=./data

# PostgreSQL connection
# Local: DB_HOST=localhost (default PostgreSQL install)
# Remote: DB_HOST=your-db-host.com
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visitors
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Set to true only if using SSL (e.g. remote/cloud PostgreSQL)
DB_SSL=false

# ==========================================
# JWT Authentication
# ==========================================
# IMPORTANT: JWT_SECRET is REQUIRED in all environments (no default fallback).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secret_key_minimum_32_characters_here

# Optional: Separate secret for refresh tokens (auto-derived from JWT_SECRET if not set)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_REFRESH_SECRET=your_refresh_secret_here

JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ==========================================
# Data Encryption (for sensitive fields)
# ==========================================
# For development only, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# PII Encryption Key (alias for ENCRYPTION_KEY, kept for forward compatibility)
# Will be used as PII_ENCRYPTION_KEY in future versions; falls back to ENCRYPTION_KEY
PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ==========================================
# Backup Configuration
# ==========================================
BACKUP_PATH=./Backups
# BACKUP_PASSWORD=your_backup_password_here

# ==========================================
# GDPR Compliance
# ==========================================
# Number of days to retain visitor personal data after checkout
DATA_RETENTION_DAYS=60

# Number of days to retain audit logs (should be longer than data retention for forensic evidence)
# Recommended: 365 minimum
AUDIT_LOG_RETENTION_DAYS=365

# ==========================================
# Security
# ==========================================
# Bcrypt rounds for password hashing (higher = more secure but slower)
# Recommended: 12 for production
BCRYPT_ROUNDS=12

# Maximum login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Rate limiting (requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Edit Protection
# ==========================================
# Password required to edit locked visitor records (bcrypt hash or plaintext)
# Leave empty to disable edit protection
EDIT_PASSWORD=

# ==========================================
# Email Configuration (for password reset)
# ==========================================
# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email sender address
EMAIL_FROM=noreply@afvisitorsystem.com

# Application URL (for password reset links)
APP_URL=http://localhost:5173

# ==========================================
# Frontend apps — Next.js public env vars
# ==========================================
# Public API URL exposed to the browser by Next apps (landing, platform, etc.)
# Backend Express server URL. In Docker, use the service name or public domain.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ==========================================
# CORS / Network (LAN access)
# ==========================================
# Comma-separated list of allowed origins for CORS
# Example: http://192.168.1.100:5173,http://192.168.1.100:3000
# ALLOWED_ORIGINS=

# ==========================================
# Seed User Passwords (for development/seeding)
# ==========================================
# These are used by the seeder to create initial users.
# Change them in production!
SEED_ROOT_PASSWORD=TrebolMaster2026!
SEED_ADMIN_PASSWORD=Trebol123*
SEED_GUARD_PASSWORD=Guard2026!@#
SEED_OPERADOR_PASSWORD=Operador2026!
SEED_AUDITOR_PASSWORD=Audit2026!@#
SEED_DEMO_PASSWORD=Demo123!@#

# ==========================================
# Multi-Tenant SaaS (Optional — defaults shown)
# ==========================================
# DEMO_EXPIRY_HOURS=24
# DEFAULT_TRIAL_DAYS=14
# DEFAULT_TENANT_MAX_USERS=5
# DEFAULT_TENANT_MAX_VISITORS=1000
# PLAN_FREE_VISITS_PER_MONTH=100
# PLAN_STARTER_VISITS_PER_MONTH=500
# PLAN_PROFESSIONAL_VISITS_PER_MONTH=2000
# PLAN_FREE_MAX_USERS=3
# PLAN_STARTER_MAX_USERS=7
# PLAN_PROFESSIONAL_MAX_USERS=21
# BACKUP_SCHEDULER_POLL_MINUTES=15
