{
  "name": "logmaster",
  "version": "1.0.0",
  "description": "LogMaster - Sistema de Control de Acceso de Visitantes",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,apps -c blue,green \"pnpm --dir server run dev\" \"turbo run dev\"",
    "dev:server": "pnpm --dir server run dev",
    "dev:landing": "pnpm --dir apps/landing run dev",
    "dev:platform": "pnpm --dir apps/platform run dev",
    "dev:admin": "pnpm --dir apps/admin run dev",
    "dev:auditor": "pnpm --dir apps/auditor run dev",
    "dev:system": "pnpm --dir apps/system run dev",
    "build": "turbo run build && pnpm --dir server run build",
    "build:server": "pnpm --dir server run build",
    "build:landing": "pnpm --dir apps/landing run build",
    "build:platform": "pnpm --dir apps/platform run build",
    "build:admin": "pnpm --dir apps/admin run build",
    "build:auditor": "pnpm --dir apps/auditor run build",
    "build:system": "pnpm --dir apps/system run build",
    "lint": "turbo run lint && pnpm --dir server run lint",
    "typecheck": "turbo run typecheck && pnpm --dir server run typecheck",
    "test": "turbo run test && pnpm --dir server run test",
    "db:setup": "pnpm --dir server run db:setup",
    "db:migrate": "pnpm --dir server run db:migrate",
    "db:seed": "pnpm --dir server run db:seed",
    "db:reset": "pnpm --dir server run db:reset",
    "clean": "rimraf \"**/dist\" \"**/build\" \"**/.turbo\" \"**/node_modules/.cache\"",
    "install:all": "pnpm install",
    "start": "pnpm --dir server run start",
    "server": "pnpm --dir server run dev",
    "install-all": "pnpm install",
    "test:server": "pnpm --dir server run test",
    "seed:clean": "pnpm --dir server run seed:clean",
    "backup": "pnpm --dir server run backup:full",
    "backup:monitor": "pnpm --dir server run backup:monitor",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "author": "Gustavo Colina (@Suggus1899)",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@11.15.0"
}
